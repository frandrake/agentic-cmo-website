---
import Logo from './Logo.astro';
import { BOOK } from '../data/book';
const year = new Date().getFullYear();
---
<footer style="margin-top: 128px; padding: 64px 0 40px; border-top: 1px solid var(--border);">
  <div class="footer-grid" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; align-items: start;">
    <div>
      <Logo />
      <p style="margin-top: 16px; font-size: 13px; color: var(--fg-muted); max-width: 360px; line-height: 1.6;">
        A book by Francesco Federico. First published {BOOK.pubDateOriginal}; second edition, {BOOK.pubDate}.
      </p>
    </div>
    <div>
      <span class="eyebrow-block">The book</span>
      <ul style="list-style: none; margin: 14px 0 0; padding: 0; display: flex; flex-direction: column; gap: 8px;">
        <li><a href="/" style="font-size: 13px; color: var(--ff-charcoal);">Home</a></li>
        <li><a href="/prompts/" style="font-size: 13px; color: var(--ff-charcoal);">Prompts</a></li>
        <li><a href="/cited/" style="font-size: 13px; color: var(--ff-charcoal);">Cited.</a></li>
        <li><a href="/about/" style="font-size: 13px; color: var(--ff-charcoal);">About</a></li>
        <li><a href={BOOK.buyUrl} target="_blank" rel="noopener" style="font-size: 13px; color: var(--ff-charcoal);">Buy the book</a></li>
      </ul>
    </div>
    <div>
      <span class="eyebrow-block">Reference</span>
      <ul style="list-style: none; margin: 14px 0 0; padding: 0; display: flex; flex-direction: column; gap: 8px;">
        <li><a href="/faq/" style="font-size: 13px; color: var(--ff-charcoal);">FAQ</a></li>
        <li><a href="/privacy/" style="font-size: 13px; color: var(--ff-charcoal);">Privacy</a></li>
        <li><a href="/llms.txt" style="font-size: 13px; color: var(--ff-charcoal);">llms.txt</a></li>
        <li><a href="mailto:press@the-agentic-cmo.com" style="font-size: 13px; color: var(--ff-charcoal);">Press</a></li>
      </ul>
    </div>
    <div>
      <span class="eyebrow-block">Elsewhere</span>
      <ul style="list-style: none; margin: 14px 0 0; padding: 0; display: flex; flex-direction: column; gap: 8px;">
        <li><a href={BOOK.newsletterSubstackUrl} target="_blank" rel="noopener" style="font-size: 13px; color: var(--ff-charcoal);">Chronicles of Change · Substack</a></li>
        <li><a href={BOOK.newsletterLinkedInUrl} target="_blank" rel="noopener" style="font-size: 13px; color: var(--ff-charcoal);">Chronicles of Change · LinkedIn</a></li>
        <li><a href="https://francescofederico.com" target="_blank" rel="noopener" style="font-size: 13px; color: var(--ff-charcoal);">francescofederico.com</a></li>
      </ul>
    </div>
  </div>
  <div style="margin-top: 64px; padding-top: 24px; border-top: 1px solid var(--border); font-size: 12px; color: var(--fg-muted);">
    © {year} Francesco Federico · All Rights Reserved
  </div>
</footer>

<style>
  @media (max-width: 880px) {
    .footer-grid { grid-template-columns: 1fr 1fr !important; }
  }
  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr !important; }
  }
</style>
