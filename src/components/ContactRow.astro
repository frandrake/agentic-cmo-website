---
import Eyebrow from './Eyebrow.astro';

export interface Props {
  label: string;
  addr: string;
  subject?: string;
}
const { label, addr, subject } = Astro.props;
const href = `mailto:${addr}${subject ? `?subject=${encodeURIComponent(subject)}` : ''}`;
---
<a href={href} style="display: grid; grid-template-columns: 180px 1fr auto; gap: 24px; padding: 20px 0; border-bottom: 1px solid var(--border); align-items: baseline; color: var(--ff-charcoal);">
  <Eyebrow>{label}</Eyebrow>
  <span style="font-family: var(--font-serif); font-size: 20px; font-weight: 600; color: var(--ff-slate-blue);">{addr}</span>
  <span style="font-size: 12px; color: var(--ff-vermillion);">Email →</span>
</a>
