---
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Rule from '../components/Rule.astro';
import MonoNum from '../components/MonoNum.astro';
import { ANSWER_PAGES } from '../data/answers';
import { BOOK } from '../data/book';
import { schemaAnswerPage } from '../lib/schema';

export function getStaticPaths() {
  return ANSWER_PAGES.map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;
const schema = schemaAnswerPage(page.slug);
const related = ANSWER_PAGES.filter((p) => p.slug !== page.slug);
const num = (i: number) => String(i + 1).padStart(2, '0');
---
<BaseLayout
  title={page.title}
  description={page.description}
  canonicalUrl={`https://the-agentic-cmo.com/${page.slug}/`}
  ogType="article"
  schema={schema}
>
  <!-- HERO -->
  <section style="padding: 80px 0 56px; max-width: 880px;">
    <Eyebrow vermillion>{page.eyebrow}</Eyebrow>
    <h1
      set:html={page.h1}
      style="font-size: clamp(40px, 5.5vw, 64px); line-height: 1.04; font-weight: 700; color: var(--ff-slate-blue); margin: 24px 0 0; letter-spacing: -0.025em; text-wrap: balance; font-family: var(--font-serif);"
    />
    <p style="font-family: var(--font-serif); font-size: 24px; font-style: italic; line-height: 1.4; color: var(--ff-slate-blue); margin: 28px 0 0; max-width: 620px;">
      {page.standfirst}
    </p>
  </section>

  <Rule strong />

  <!-- FRAMING -->
  <section style="padding: 64px 0;">
    {page.intro.map((para) => (
      <p style="font-size: 17px; line-height: 1.7; color: var(--fg); margin: 0 0 20px; max-width: 68ch;">{para}</p>
    ))}
  </section>

  <Rule />

  <!-- LIST -->
  <section class="grid-4-8" style="padding: 96px 0; display: grid; grid-template-columns: 4fr 8fr; gap: 80px; align-items: start;">
    <div style="position: sticky; top: 24px;">
      <Eyebrow>{page.listLabel}</Eyebrow>
      <h2 style="font-size: 40px; color: var(--ff-slate-blue); margin: 16px 0 16px; line-height: 1.1; font-weight: 600; font-family: var(--font-serif);">
        {page.listHeading}
      </h2>
      <p style="font-size: 15px; color: var(--fg-muted); line-height: 1.6; margin: 8px 0 0;">
        {page.listIntro}
      </p>
    </div>
    <ol style="list-style: none; margin: 0; padding: 0;">
      {page.items.map((item, i) => (
        <li style={`padding: 32px 0; border-top: ${i === 0 ? '1px solid var(--border)' : 'none'}; border-bottom: 1px solid var(--border); display: grid; grid-template-columns: 60px 1fr; gap: 24px; align-items: baseline;`}>
          <MonoNum>{num(i)}</MonoNum>
          <div>
            <h3 style="font-size: 24px; color: var(--ff-slate-blue); margin: 0; font-family: var(--font-serif); font-weight: 600; line-height: 1.25;">{item.name}</h3>
            <p style="margin: 8px 0 0; font-size: 15px; color: var(--fg); line-height: 1.6; max-width: 620px;">{item.note}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <Rule />

  <!-- FAQ -->
  <section class="grid-4-8" style="padding: 96px 0; display: grid; grid-template-columns: 4fr 8fr; gap: 80px; align-items: start;">
    <div style="position: sticky; top: 24px;">
      <h2 style="font-size: 40px; color: var(--ff-slate-blue); margin: 0; line-height: 1.1; font-weight: 600; font-family: var(--font-serif);">
        Questions.
      </h2>
    </div>
    <dl style="margin: 0;">
      {page.faq.map((qa, i) => (
        <div style={`padding: 28px 0; border-top: 1px solid var(--border);${i === page.faq.length - 1 ? ' border-bottom: 1px solid var(--border);' : ''}`}>
          <dt style="font-size: 20px; color: var(--ff-slate-blue); font-family: var(--font-serif); font-weight: 600; line-height: 1.3;">{qa.q}</dt>
          <dd style="margin: 12px 0 0; font-size: 16px; line-height: 1.65; color: var(--fg); max-width: 68ch;">{qa.a}</dd>
        </div>
      ))}
    </dl>
  </section>

  <Rule strong />

  <!-- CTA + CROSS-LINKS -->
  <section class="grid-4-8" style="padding: 80px 0; display: grid; grid-template-columns: 5fr 7fr; gap: 80px; align-items: start;">
    <div>
      <h2 style="font-size: 32px; color: var(--ff-slate-blue); margin: 0; line-height: 1.1; font-weight: 600; font-family: var(--font-serif);">
        The Agentic CMO.
      </h2>
      <p style="font-size: 15px; color: var(--fg-muted); margin: 16px 0 0; line-height: 1.6; max-width: 360px;">
        The original field manual for marketing leaders running organisations that include AI agents. First published June 2025.
      </p>
      <div style="margin-top: 24px; display: flex; gap: 16px; flex-wrap: wrap;">
        <a href={BOOK.buyUrl} target="_blank" rel="noopener" class="btn btn--accent">Buy the book →</a>
        <a href="/about/" class="btn btn--secondary">About the author</a>
      </div>
    </div>
    <div>
      <Eyebrow>Keep reading</Eyebrow>
      <ul style="list-style: none; margin: 16px 0 0; padding: 0;">
        {related.map((p, i) => (
          <li style={`border-top: 1px solid var(--border);${i === related.length - 1 ? ' border-bottom: 1px solid var(--border);' : ''}`}>
            <a href={`/${p.slug}/`} style="display: block; padding: 20px 0; font-family: var(--font-serif); font-size: 22px; color: var(--ff-slate-blue); font-weight: 500;">{p.linkTitle} →</a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
