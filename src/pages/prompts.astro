---
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Rule from '../components/Rule.astro';
import PromptList from '../components/PromptList.tsx';
import { PROMPTS, THEMES, CHAPTER_NUMBERS } from '../data/prompts';
import { BOOK } from '../data/book';

const promptsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'The 24 Activate This prompts',
  description: 'Production-ready prompts from The Agentic CMO, free to use with frontier models such as Claude or ChatGPT.',
  url: `${BOOK.url}/prompts/`,
  isPartOf: { '@id': `${BOOK.url}/#website` },
  about: { '@id': `${BOOK.url}/#book` },
  hasPart: PROMPTS.map((p) => ({
    '@type': 'CreativeWork',
    name: p.title,
    description: p.context,
    url: `${BOOK.url}/prompts/#${p.id}`,
    isPartOf: { '@id': `${BOOK.url}/#book` },
    keywords: [p.theme, p.chapterTitle].join(', '),
  })),
};
---
<BaseLayout
  title="The Activate This prompts"
  description="The full set of production-ready prompts from The Agentic CMO. Filter by theme or chapter, copy in one click, or open directly in Claude or ChatGPT."
  jsonLd={promptsJsonLd}
>
  <section class="prompts-header" style="padding: 64px 0 48px; display: grid; grid-template-columns: 7fr 5fr; gap: 80px; align-items: end;">
    <div>
      <Eyebrow vermillion>The {PROMPTS.length} Activate This prompts</Eyebrow>
      <h1 style="font-size: 64px; color: var(--ff-slate-blue); margin: 24px 0 0; line-height: 1.04; font-weight: 700; font-family: var(--font-serif); letter-spacing: -0.02em; text-wrap: balance;">
        Prompts<br />from the book.
      </h1>
    </div>
    <div>
      <p style="font-size: 17px; color: var(--fg); margin: 0; line-height: 1.55; max-width: 460px;">
        Each chapter ends with one or more production-ready prompts. They live here so they remain useful — copy them, edit them, run them in Claude or ChatGPT.
      </p>
      <p style="font-size: 13px; color: var(--fg-muted); margin: 20px 0 0; max-width: 460px;">
        Free to use, with or without the book. Variables in <code style="color: var(--ff-vermillion);">{`{{double_braces}}`}</code> are placeholders.
      </p>
    </div>
  </section>

  <Rule strong margin="16px 0 0" />

  <PromptList client:load prompts={PROMPTS} themes={THEMES} chapters={CHAPTER_NUMBERS} />
</BaseLayout>

<style>
  @media (max-width: 880px) {
    .prompts-header { grid-template-columns: 1fr !important; gap: 32px !important; }
    h1 { font-size: 44px !important; }
  }
</style>
